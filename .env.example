# Urbaphix frontend environment template (Vite)
# Copy this file to the local mode-specific file you need:
# - .env.development for DEV (urbaphix-dev)
# - .env.qa for QA (urbaphix-qa)
# - .env.production for PROD (Urbaphix producción)
#
# Do not commit real .env.* files or private/service_role keys.

# Supabase project URL for the selected environment.
# Example format only; replace the project ref per environment locally.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase anon public key for the selected environment.
# Never use service_role or private keys in the frontend.
VITE_SUPABASE_ANON_KEY=<supabase-anon-public-key>

# DEV/local only: enables the hybrid tenant_memberships resolver with usuarios_app fallback.
# Keep false/absent outside controlled DEV validation unless explicitly approved.
VITE_ENABLE_MEMBERSHIP_RESOLVER=false
